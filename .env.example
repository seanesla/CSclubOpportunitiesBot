# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_application_id_here
DISCORD_GUILD_ID=your_test_guild_id_here_optional

# Discord Channel IDs
DIGEST_CHANNEL_ID=your_digest_channel_id_here

# Turso Database Configuration
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# USAJOBS API Configuration
# Get your API key from: https://developer.usajobs.gov/APIRequest/Index
USAJOBS_API_KEY=your_usajobs_api_key_here
USAJOBS_USER_AGENT=your_email@example.com

# Nominatim Geocoding Configuration (OpenStreetMap)
# Format: Your-App-Name/Version (your-email@example.com)
NOMINATIM_USER_AGENT=SMC-CS-Opportunities-Bot/1.0 (your-email@example.com)

# Bot Configuration
NODE_ENV=production
LOG_LEVEL=info

# Rate Limiting Configuration
RATE_LIMIT_DELAY_MS=1000
GEOCODING_DELAY_MS=1200

# Scheduling Configuration (cron format)
# Default: "0 9 */3 * *" (every 3 days at 9 AM)
DIGEST_CRON_SCHEDULE=0 9 */3 * *

# SMC Location (Santa Monica College)
SMC_LATITUDE=34.0168
SMC_LONGITUDE=-118.4695

# California Bounds (for filtering)
CA_NORTH_BOUND=42.0
CA_SOUTH_BOUND=32.5
CA_EAST_BOUND=-114.1
CA_WEST_BOUND=-124.4

# Posting Configuration
MIN_OPPORTUNITIES_PER_POST=5
MAX_OPPORTUNITIES_PER_POST=8
