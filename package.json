{
  "name": "smc-cs-opportunities-bot",
  "version": "1.0.0",
  "description": "Discord bot aggregating CS opportunities for Santa Monica College students",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "NODE_ENV=development node --watch src/index.js",
    "register-commands": "node src/scripts/register-commands.js",
    "register-guild-commands": "node src/scripts/register-guild-commands.js",
    "db:migrate": "node src/scripts/migrate.js",
    "db:seed": "node src/scripts/seed.js",
    "lint": "eslint src/"
  },
  "keywords": [
    "discord",
    "bot",
    "internships",
    "hackathons",
    "opportunities",
    "college",
    "students"
  ],
  "author": "Sean Esla <seanesla1156@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "discord.js": "^14.22.1",
    "dotenv": "^16.4.7",
    "node-cron": "^3.0.3",
    "node-fetch": "^3.3.2",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "eslint": "^9.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
